rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================================
    // STREAM FLIX — FIREBASE STORAGE SECURITY RULES
    // Personal use: only authenticated users can upload/download.
    // ============================================================

    // Default: DENY everything
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Videos folder: authenticated users only, max 5GB per file
    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 * 1024  // 5GB limit
                   && request.resource.contentType.matches('video/.*');
      allow delete: if request.auth != null;
    }

    // Thumbnails folder: authenticated users only, max 10MB
    match /thumbnails/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10MB limit
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

  }
}
