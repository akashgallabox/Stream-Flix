# ============================================================
# STREAM FLIX - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your real values.
# !! NEVER put real values in this file !!
# ============================================================

# --- Firebase Configuration ---
# Get these from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_DATABASE_ID=YOUR_FIRESTORE_DATABASE_ID

# --- App Login Credentials (Personal Use) ---
VITE_APP_USERNAME=Akashktech
VITE_APP_PASSWORD=Akash@2000#

# --- Upload API Protection Token ---
# Anyone who wants to upload must provide this as Authorization: Bearer <token>
UPLOAD_SECRET_TOKEN=your_secure_upload_token

# --- App URL ---
APP_URL=https://stream-flix-jet.vercel.app/
